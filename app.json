{
  "expo": {
    "name": "ANIMA",
    "slug": "anima",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "anima",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.animapet.app",
      "infoPlist": {
        "NSCameraUsageDescription": "ANIMA needs camera access to scan BioCard diagnostic cartridges.",
        "NSPhotoLibraryUsageDescription": "ANIMA uses photos to analyze your pet's visual health indicators.",
        "NSLocationWhenInUseUsageDescription": "ANIMA uses your location for environmental health risk assessments.",
        "NSMicrophoneUsageDescription": "ANIMA listens for coughs and breathing patterns to monitor respiratory health. Audio never leaves your device."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.animapet.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-image-picker",
      "expo-location",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#10B981"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
